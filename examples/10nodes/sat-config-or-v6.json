{
  "node-config-common": [
    {
      "match-key": "type",
      "match-value": "satellite",
      "config-common": {
        "type": "undefined",
        "n_antennas": 2,
        "metadata": {},
        "image": "msvcbench/sat-container:latest",
        "sidecars": [],
        "cpu-request": "100m",
        "mem-request": "200MiB",
        "L3-config": {
          "enable-netem": true,
          "enable-routing": false,
          "auto-assign-ips": true,
          "auto-assign-super-cidr": [
            {
              "match-key": "type",
              "match-value": "satellite",
              "super-cidr6": "2001:db8:100::/48"
            }
          ]
        }
      }
    },
    {
      "match-key": "type",
      "match-value": "gateway",
      "config-common": {
        "type": "undefined",
